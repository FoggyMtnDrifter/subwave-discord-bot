# Discord Bot Configuration
# Copy this file to .env and fill in your values.

# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal → Bot → Token
DISCORD_TOKEN=

# Application (client) ID from Discord Developer Portal → General Information
CLIENT_ID=

# Optional: set this to your server's ID for instant guild-scoped command
# registration during development. Leave blank for global registration (~1h).
GUILD_ID=

# ── SUB/WAVE Instance ─────────────────────────────────────────────────────────
# Base URL of your SUB/WAVE controller (the web-facing URL, port 7700 in dev).
# Example: https://radio.example.com  or  http://localhost:7700
SUBWAVE_URL=

# Icecast stream URL. Each guild connection opens one HTTP listener here.
# Example: http://radio.example.com:7702/stream.mp3
# In prod, this is typically on port 7702. The stream path is usually /stream.mp3
SUBWAVE_STREAM_URL=

# ── SUB/WAVE Admin Credentials (optional) ─────────────────────────────────────
# Required for the /search command (uses the admin-gated GET /dj/search endpoint).
# Leave blank to disable /search entirely.
ADMIN_USER=
ADMIN_PASS=
